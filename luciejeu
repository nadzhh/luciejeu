<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Le Grand Défi Mystère</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;1,300&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root{
  --gold:#c9a84c;--gold-light:#f0d080;--cream:#f5edd8;
  --dark:#0a0a0a;--ok:#4caf77;--err:#c94c4c;
}

body{
  background:var(--dark);min-height:100vh;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;color:var(--cream);overflow:hidden;
}

/* BG */
#bgc{position:fixed;inset:0;pointer-events:none;z-index:0;}

/* TOP BAR */
#progress-track{position:fixed;top:0;left:0;width:100%;height:3px;background:rgba(201,168,76,.12);z-index:100;}
#progress-fill{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold-light));transition:width 1s ease;box-shadow:0 0 8px var(--gold);width:0%;}
#hud{position:fixed;top:12px;left:0;right:0;display:flex;justify-content:space-between;padding:0 20px;z-index:100;pointer-events:none;}
#hud span{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:rgba(201,168,76,.4);opacity:0;transition:opacity .5s;}

/* SECTIONS */
.section{display:none;flex-direction:column;align-items:center;justify-content:center;
  width:100%;min-height:100vh;padding:60px 20px 40px;position:relative;z-index:1;
  animation:fsIn .55s ease forwards;}
.section.active{display:flex;}

@keyframes fsIn{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}

/* CARD */
.card{background:#0f0f0f;border:1px solid rgba(201,168,76,.18);border-radius:4px;
  padding:clamp(28px,5vw,44px);max-width:520px;width:100%;
  box-shadow:0 0 60px rgba(201,168,76,.05);
  display:flex;flex-direction:column;align-items:center;gap:24px;}

/* TYPE */
.badge{font-size:10px;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);opacity:.7;text-align:center;}
.title{font-family:'Playfair Display',serif;font-size:clamp(26px,5vw,46px);text-align:center;line-height:1.2;}
.title-gold{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(18px,3vw,26px);color:var(--gold);text-align:center;}
.sub{font-size:clamp(14px,2vw,17px);color:rgba(245,237,216,.6);text-align:center;line-height:1.7;}
.qcount{font-size:11px;letter-spacing:.3em;color:rgba(201,168,76,.5);text-transform:uppercase;}
.qtext{font-family:'Playfair Display',serif;font-size:clamp(17px,2.8vw,22px);text-align:center;line-height:1.5;}
.feedback{font-style:italic;font-size:14px;text-align:center;min-height:22px;color:var(--gold);transition:opacity .3s;}
.sep{width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);}

/* BUTTONS */
.btn{padding:13px 36px;background:transparent;border:1px solid var(--gold);
  color:var(--gold);font-family:'Cormorant Garamond',serif;font-size:16px;
  letter-spacing:.15em;cursor:pointer;transition:all .25s;border-radius:2px;text-transform:uppercase;}
.btn:hover{background:rgba(201,168,76,.1);box-shadow:0 0 20px rgba(201,168,76,.2);}
.btn.solid{background:var(--gold);color:var(--dark);font-weight:700;}
.btn.solid:hover{background:var(--gold-light);box-shadow:0 0 30px rgba(201,168,76,.4);}

/* MCQ OPTIONS */
.opts{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;}
.opt{padding:13px 10px;background:rgba(255,255,255,.02);border:1px solid rgba(201,168,76,.14);
  color:var(--cream);font-family:'Cormorant Garamond',serif;font-size:15px;
  cursor:pointer;border-radius:3px;transition:all .2s;text-align:center;line-height:1.3;}
.opt:hover:not(:disabled){border-color:var(--gold);background:rgba(201,168,76,.07);}
.opt.ok{border-color:var(--ok);background:rgba(76,175,119,.13);color:#80ffb0;}
.opt.err{border-color:var(--err);background:rgba(201,76,76,.13);color:#ff9090;}
.opt:disabled{cursor:default;}

/* VF */
.vf-row{display:flex;gap:14px;width:100%;}
.vfb{flex:1;padding:18px;font-family:'Playfair Display',serif;font-size:20px;
  cursor:pointer;border-radius:3px;border:1px solid;transition:all .2s;letter-spacing:.05em;}
.vfb.t{border-color:rgba(76,175,119,.35);color:#80ffb0;background:rgba(76,175,119,.05);}
.vfb.f{border-color:rgba(201,76,76,.35);color:#ff9090;background:rgba(201,76,76,.05);}
.vfb:hover:not(:disabled){transform:scale(1.03);box-shadow:0 0 16px rgba(201,168,76,.18);}
.vfb.ok{background:rgba(76,175,119,.22);border-color:var(--ok);}
.vfb.err{background:rgba(201,76,76,.22);border-color:var(--err);}

/* MEMORY */
#mem-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;max-width:340px;width:100%;}
.mc{aspect-ratio:1;border:1px solid rgba(201,168,76,.2);border-radius:4px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:26px;
  transition:all .25s;user-select:none;position:relative;overflow:hidden;
  background:rgba(255,255,255,.02);}
.mc .bk{position:absolute;inset:0;background:linear-gradient(135deg,#1a1508,#1e1a0a);
  display:flex;align-items:center;justify-content:center;font-size:18px;
  color:rgba(201,168,76,.3);transition:opacity .25s;}
.mc.flip .bk,.mc.mat .bk{opacity:0;}
.mc.mat{border-color:rgba(76,175,119,.35);background:rgba(76,175,119,.07);cursor:default;}
.mc:hover:not(.flip):not(.mat){border-color:rgba(201,168,76,.5);transform:scale(1.06);}

/* REACTION */
#react-area{position:relative;width:min(400px,90vw);height:280px;
  background:rgba(255,255,255,.02);border:1px solid rgba(201,168,76,.14);
  border-radius:4px;overflow:hidden;}
.target{position:absolute;width:54px;height:54px;border-radius:50%;
  background:radial-gradient(circle,var(--gold-light),var(--gold));
  cursor:pointer;transform:translate(-50%,-50%);
  animation:tpop .12s ease;box-shadow:0 0 18px rgba(201,168,76,.5);
  display:flex;align-items:center;justify-content:center;font-size:22px;}
@keyframes tpop{from{transform:translate(-50%,-50%) scale(0);}to{transform:translate(-50%,-50%) scale(1);}}
#r4-bar{position:absolute;bottom:0;left:0;height:4px;background:var(--gold);
  width:100%;box-shadow:0 0 8px var(--gold);}
.stat-box{display:flex;flex-direction:column;align-items:center;gap:4px;}
.stat-n{font-family:'Playfair Display',serif;font-size:clamp(44px,7vw,70px);color:var(--gold);line-height:1;}
.stat-l{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:rgba(201,168,76,.45);}

/* TRANSITION OVERLAY */
#rt{position:fixed;inset:0;background:var(--dark);z-index:200;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;
  opacity:0;pointer-events:none;transition:opacity .35s ease;}
#rt.on{opacity:1;pointer-events:all;}
#rt .rn{font-family:'Playfair Display',serif;font-size:clamp(70px,14vw,110px);
  color:var(--gold);opacity:.1;line-height:1;}
#rt .rnm{font-family:'Playfair Display',serif;font-style:italic;
  font-size:clamp(22px,4vw,34px);color:var(--gold);letter-spacing:.08em;}
#rt .rnd{font-size:12px;color:rgba(245,237,216,.4);letter-spacing:.2em;text-transform:uppercase;}

/* SCRATCH */
.scratch-wrap{padding:3px;
  background:linear-gradient(135deg,var(--gold) 0%,#8b6914 40%,var(--gold-light) 60%,#8b6914 100%);
  border-radius:4px;box-shadow:0 0 60px rgba(201,168,76,.15);}
.scratch-inner{position:relative;width:min(420px,90vw);height:220px;border-radius:2px;overflow:hidden;background:#111;}
.msg-layer{position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;padding:28px;gap:12px;background:#0d0d0d;
  visibility:hidden;}
.msg-text{font-family:'Playfair Display',serif;font-size:clamp(15px,3.5vw,20px);
  color:var(--cream);text-align:center;line-height:1.6;}
.msg-sub{font-style:italic;font-size:clamp(12px,2.5vw,15px);color:var(--gold);text-align:center;}
#sc{position:absolute;inset:0;z-index:2;border-radius:2px;cursor:crosshair;background:#1a1508;}
.pb-wrap{width:min(420px,90vw);display:flex;flex-direction:column;align-items:flex-end;gap:5px;}
.pb-lbl{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:rgba(201,168,76,.45);}
.pb{width:100%;height:1px;background:rgba(201,168,76,.12);}
.pb-fill{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold-light));transition:width .3s;}

/* SPARKLE / PETAL */
.sparkle{position:fixed;border-radius:50%;background:var(--gold-light);
  pointer-events:none;z-index:20;animation:sfx .9s ease-out forwards;}
@keyframes sfx{0%{transform:translate(0,0) scale(1);opacity:1;}100%{transform:translate(var(--tx),var(--ty)) scale(0);opacity:0;}}
.petal{position:fixed;pointer-events:none;z-index:15;font-size:16px;
  animation:pfall linear forwards;opacity:.7;}
@keyframes pfall{0%{transform:translateY(-20px) rotate(0deg);opacity:.8;}100%{transform:translateY(110vh) rotate(720deg);opacity:0;}}
</style>
</head>
<body>

<canvas id="bgc"></canvas>
<div id="progress-track"><div id="progress-fill"></div></div>
<div id="hud"><span id="hud-l">Score : <span id="score-v">0</span></span><span id="hud-r">Manche 1/5</span></div>

<!-- TRANSITION -->
<div id="rt"><div class="rn" id="rt-n">1</div><div class="rnm" id="rt-nm">Énigmes</div><div class="rnd" id="rt-d">3 questions</div></div>

<!-- ══ INTRO ══ -->
<div class="section active" id="s-intro">
  <div class="card">
    <p class="badge">✦ Le Grand Défi Mystère ✦</p>
    <h1 class="title">Prouve que<br>t'es intelligent(e)</h1>
    <div class="sep"></div>
    <p class="sub">5 manches. Des questions qui piquent.<br>Une récompense mystérieuse à la fin.<br><em style="color:rgba(201,168,76,.6)">Si tu y arrives.</em></p>
    <button class="btn solid" onclick="startGame()">Accepter le défi →</button>
  </div>
</div>

<!-- ══ R1 : LOGIQUE ══ -->
<div class="section" id="s-r1">
  <div class="card">
    <p class="badge">Manche 1 · Énigmes</p>
    <p class="qcount" id="r1-ct">Question 1/3</p>
    <p class="qtext" id="r1-q"></p>
    <div class="opts" id="r1-opts"></div>
    <p class="feedback" id="r1-fb"></p>
  </div>
</div>

<!-- ══ R2 : CALCUL ══ -->
<div class="section" id="s-r2">
  <div class="card">
    <p class="badge">Manche 2 · Calcul Mental</p>
    <p class="qcount" id="r2-ct">Question 1/3</p>
    <p class="qtext" id="r2-q"></p>
    <div class="opts" id="r2-opts"></div>
    <p class="feedback" id="r2-fb"></p>
  </div>
</div>

<!-- ══ R3 : MÉMOIRE ══ -->
<div class="section" id="s-r3">
  <div class="card" style="max-width:420px">
    <p class="badge">Manche 3 · Jeu de Mémoire</p>
    <p class="sub" id="r3-st">Retrouve toutes les paires !</p>
    <div id="mem-grid"></div>
    <p class="feedback" id="r3-fb" style="opacity:0">.</p>
  </div>
</div>

<!-- ══ R4 : RÉACTION ══ -->
<div class="section" id="s-r4">
  <div class="card" style="max-width:480px">
    <p class="badge">Manche 4 · Réflexes</p>
    <p class="sub">Clique sur les cibles avant qu'elles disparaissent !</p>
    <div style="display:flex;gap:32px;justify-content:center">
      <div class="stat-box"><span class="stat-n" id="r4-hits">0</span><span class="stat-l">touchés</span></div>
      <div class="stat-box"><span class="stat-n" id="r4-rem">8</span><span class="stat-l">à venir</span></div>
    </div>
    <div id="react-area"><div id="r4-bar"></div></div>
    <p class="feedback" id="r4-fb" style="opacity:0">.</p>
  </div>
</div>

<!-- ══ R5 : VRAI/FAUX ══ -->
<div class="section" id="s-r5">
  <div class="card">
    <p class="badge">Manche 5 · Vrai ou Faux</p>
    <p class="qcount" id="r5-ct">Question 1/4</p>
    <p class="qtext" id="r5-q"></p>
    <div class="vf-row">
      <button class="vfb t" id="vf-t" onclick="answerVF(true)">✓ Vrai</button>
      <button class="vfb f" id="vf-f" onclick="answerVF(false)">✗ Faux</button>
    </div>
    <p class="feedback" id="r5-fb"></p>
  </div>
</div>

<!-- ══ R6 : TU ME CONNAIS ? ══ -->
<div class="section" id="s-r6">
  <div class="card">
    <p class="badge">Manche 6 · Tu me connais bien ?</p>
    <p class="qcount" id="r6-ct">Question 1/5</p>
    <p class="qtext" id="r6-q"></p>
    <div class="opts" id="r6-opts"></div>
    <p class="feedback" id="r6-fb"></p>
  </div>
</div>

<!-- ══ SCORE FINAL ══ -->
<div class="section" id="s-score">
  <div class="card">
    <p class="badge">✦ Résultat Final ✦</p>
    <div style="font-family:'Playfair Display',serif;font-size:clamp(52px,9vw,84px);color:var(--gold);line-height:1" id="final-sc"></div>
    <p class="stat-l">points récoltés</p>
    <div class="sep"></div>
    <p class="sub" id="final-cm"></p>
    <div class="sep"></div>
    <p class="sub">Tu as survécu aux 5 manches.<br>Il reste une chose à découvrir...</p>
    <button class="btn solid" onclick="showScratch()">Révéler la récompense →</button>
  </div>
</div>

<!-- ══ SCRATCH ══ -->
<div class="section" id="s-scratch">
  <div style="display:flex;flex-direction:column;align-items:center;gap:24px">
    <div style="display:flex;flex-direction:column;align-items:center;gap:8px">
      <p class="badge">✦ Ta Récompense ✦</p>
      <p class="title-gold">Gratte pour découvrir...</p>
    </div>
    <div class="scratch-wrap">
      <div class="scratch-inner">
        <div class="msg-layer">
          <div class="msg-text">Veux-tu manger à l'Adriatico<br>avec moi ce soir&nbsp;?</div>
          <div class="msg-sub">( trop tard, j'ai déjà réservé )</div>
        </div>
        <canvas id="sc"></canvas>
      </div>
    </div>
    <div class="pb-wrap">
      <span class="pb-lbl">Révélé — <span id="sc-pct">0</span>%</span>
      <div class="pb"><div class="pb-fill" id="sc-fill" style="width:0%"></div></div>
    </div>
    <p class="sub" style="font-style:italic;opacity:.35;font-size:13px">gratte avec ta souris (ou le doigt)</p>
  </div>
</div>

<script>
// ─── BG STARS ───
const bgc=document.getElementById('bgc');const bgx=bgc.getContext('2d');
let pts=[];
function rBg(){bgc.width=innerWidth;bgc.height=innerHeight;}rBg();
window.addEventListener('resize',rBg);
for(let i=0;i<110;i++)pts.push({x:Math.random()*innerWidth,y:Math.random()*innerHeight,r:Math.random()*1.2,ph:Math.random()*Math.PI*2,sp:0.003+Math.random()*0.007});
(function aBg(t){bgx.clearRect(0,0,bgc.width,bgc.height);pts.forEach(p=>{const a=0.1+0.5*Math.abs(Math.sin(t*p.sp+p.ph));bgx.beginPath();bgx.arc(p.x,p.y,p.r,0,Math.PI*2);bgx.fillStyle=`rgba(201,168,76,${a})`;bgx.fill();});requestAnimationFrame(aBg);})(0);

// ─── SCORE & HUD ───
let score=0;
const MAX=24;// 3+3+6+8+4 (R6 bonus hors MAX)
function addScore(n){score+=n;document.getElementById('score-v').textContent=score;}
function setHud(round){
  document.getElementById('hud-l').style.opacity='1';
  document.getElementById('hud-r').style.opacity='1';
  document.getElementById('hud-r').textContent=`Manche ${round}/6`;
  document.getElementById('progress-fill').style.width=((round-1)/6*100)+'%';
}

// ─── SECTIONS ───
function show(id){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ─── ROUND TRANSITION ───
// cb() s'exécute SOUS l'overlay encore opaque, puis l'overlay se retire → jamais de trou entre sections
function transition(num,name,desc,cb){
  const rt=document.getElementById('rt');
  document.getElementById('rt-n').textContent=num;
  document.getElementById('rt-nm').textContent=name;
  document.getElementById('rt-d').textContent=desc;
  rt.classList.add('on');
  setTimeout(()=>{cb();setTimeout(()=>rt.classList.remove('on'),80);},1700);
}

// ─── MCQ HELPER ───
function renderMCQ(containerId,feedbackId,opts,ansIdx,onDone){
  const c=document.getElementById(containerId);
  const fb=document.getElementById(feedbackId);
  fb.textContent='';c.innerHTML='';
  opts.forEach((o,i)=>{
    const b=document.createElement('button');
    b.className='opt';b.textContent=o.label;
    b.onclick=()=>{
      c.querySelectorAll('.opt').forEach(x=>x.disabled=true);
      const ok=i===ansIdx;
      b.classList.add(ok?'ok':'err');
      if(!ok)c.querySelectorAll('.opt')[ansIdx].classList.add('ok');
      if(ok)addScore(1);
      fb.textContent=ok?o.rightComment:o.wrongComment;
      setTimeout(onDone,1900);
    };
    c.appendChild(b);
  });
}

// ══════════════════════════════
// INTRO
// ══════════════════════════════
function startGame(){
  transition(1,'Énigmes','3 questions de logique',()=>{initR1();show('s-r1');setHud(1);});
}

// ══════════════════════════════
// R1 : LOGIQUE
// ══════════════════════════════
const R1=[
  {
    q:"J'ai des dents mais je ne mords jamais. Que suis-je ?",
    opts:[
      {label:"Un vampire végétarien",rightComment:"",wrongComment:"Un vampire végétarien... originalité 0/10. C'est un peigne 🪮"},
      {label:"Un peigne",rightComment:"Facile pour commencer ! C'est bien un peigne 🪮",wrongComment:""},
      {label:"Une fermeture éclair",rightComment:"",wrongComment:"Non non. C'est un peigne 🪮"},
      {label:"Ton sourire un lundi",rightComment:"",wrongComment:"Ton humour oui, mais la réponse c'est un peigne 🪮"}
    ],ans:1
  },
  {
    q:"Plus je grandis, moins on me voit. Que suis-je ?",
    opts:[
      {label:"Ta carrière",rightComment:"",wrongComment:"Je ne commenterai pas. C'est l'obscurité 🌑"},
      {label:"L'obscurité",rightComment:"Exactement ! L'obscurité. T'as de la jugeote ✨",wrongComment:""},
      {label:"Un bébé",rightComment:"",wrongComment:"Un bébé ? Non. L'obscurité 🌑"},
      {label:"Le soleil",rightComment:"",wrongComment:"Le soleil... c'est le contraire ! C'est l'obscurité 🌑"}
    ],ans:1
  },
  {
    q:"J'ai une tête et une queue, mais pas de corps ni de pattes. Que suis-je ?",
    opts:[
      {label:"Un chat mutant",rightComment:"",wrongComment:"Un chat mutant 😭 Non. C'est une pièce de monnaie 🪙"},
      {label:"Un serpent philosophe",rightComment:"",wrongComment:"Un serpent philosophe... Non. C'est une pièce de monnaie 🪙"},
      {label:"Une pièce de monnaie",rightComment:"Bien joué ! Pile ou face 🪙",wrongComment:""},
      {label:"La comète Halley",rightComment:"",wrongComment:"La comète... Non. Pièce de monnaie 🪙"}
    ],ans:2
  }
];
let r1i=0;
function initR1(){r1i=0;doR1();}
function doR1(){
  if(r1i>=R1.length){endR1();return;}
  const q=R1[r1i];
  document.getElementById('r1-ct').textContent=`Question ${r1i+1}/3`;
  document.getElementById('r1-q').textContent=q.q;
  renderMCQ('r1-opts','r1-fb',q.opts,q.ans,()=>{r1i++;doR1();});
}
function endR1(){
  transition(2,'Calcul Mental','3 opérations à résoudre',()=>{initR2();show('s-r2');setHud(2);});
}

// ══════════════════════════════
// R2 : CALCUL
// ══════════════════════════════
const R2=[
  {
    q:"37 + 58 = ?",
    opts:[
      {label:"87",rightComment:"",wrongComment:"37+58 = 95. Les doigts c'est pour les pros 😅"},
      {label:"95",rightComment:"37+58=95 ! Calculatrice humaine 🧠",wrongComment:""},
      {label:"93",rightComment:"",wrongComment:"Non, c'est 95. Recalcule tranquillement 😅"},
      {label:"99",rightComment:"",wrongComment:"Trop haut ! C'est 95 😅"}
    ],ans:1
  },
  {
    q:"13 × 7 = ?",
    opts:[
      {label:"81",rightComment:"",wrongComment:"13×7=91. La table de 13 c'est optionnel visiblement 😬"},
      {label:"84",rightComment:"",wrongComment:"Presque mais non ! C'est 91 🙄"},
      {label:"97",rightComment:"",wrongComment:"97 ? Non. C'est 91 😅"},
      {label:"91",rightComment:"13×7=91 ! Bien calculé 💥",wrongComment:""}
    ],ans:3
  },
  {
    q:"144 ÷ 12 = ?",
    opts:[
      {label:"11",rightComment:"",wrongComment:"144÷12=12. C'était juste à côté 🙄"},
      {label:"12",rightComment:"144÷12=12 ! Parfait 🎯",wrongComment:""},
      {label:"13",rightComment:"",wrongComment:"Un de trop ! C'est 12 😅"},
      {label:"14",rightComment:"",wrongComment:"Non, 144÷12=12. Retente 😅"}
    ],ans:1
  }
];
let r2i=0;
function initR2(){r2i=0;doR2();}
function doR2(){
