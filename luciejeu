// SCRATCH
// ══════════════════════════════
function showScratch(){
  document.getElementById('hud-l').style.opacity='0';
  document.getElementById('hud-r').style.opacity='0';
  show('s-scratch');
  setTimeout(initScratch,120); // attendre que la section soit rendue (offsetWidth > 0)
}

function initScratch(){
  const sc=document.getElementById('sc');
  const ci=sc.parentElement;
  sc.width=ci.offsetWidth;sc.height=ci.offsetHeight;
  const ctx=sc.getContext('2d');
  const g=ctx.createLinearGradient(0,0,sc.width,sc.height);
  g.addColorStop(0,'#1a1508');g.addColorStop(.5,'#1e1a0a');g.addColorStop(1,'#141008');
  ctx.fillStyle=g;ctx.fillRect(0,0,sc.width,sc.height);
  for(let i=0;i<600;i++){
    ctx.beginPath();ctx.arc(Math.random()*sc.width,Math.random()*sc.height,Math.random()*.8,0,Math.PI*2);
    ctx.fillStyle=`rgba(201,168,76,${Math.random()*.12})`;ctx.fill();
  }
  // grid lines
  for(let i=0;i<6;i++){
    ctx.strokeStyle=`rgba(201,168,76,${.03+Math.random()*.05})`;ctx.lineWidth=.5;
    ctx.beginPath();ctx.moveTo(0,Math.random()*sc.height);ctx.lineTo(sc.width,Math.random()*sc.height);ctx.stroke();
  }
  ctx.fillStyle='rgba(201,168,76,.48)';
  ctx.font=`italic ${sc.height*.09}px 'Cormorant Garamond',serif`;
  ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText('✦ GRATTE ICI ✦',sc.width/2,sc.height/2-10);
  ctx.font=`${sc.height*.055}px 'Cormorant Garamond',serif`;
  ctx.fillStyle='rgba(201,168,76,.26)';
  ctx.fillText('ta récompense t\'attend',sc.width/2,sc.height/2+28);
  ctx.globalCompositeOperation='destination-out';
  // Le canvas couvre maintenant le msg-layer : on peut le rendre visible
  ci.querySelector('.msg-layer').style.visibility='visible';

  let isS=false,done=false;
  function gPos(e){const r=sc.getBoundingClientRect();const s=e.touches?e.touches[0]:e;return{x:(s.clientX-r.left)*(sc.width/r.width),y:(s.clientY-r.top)*(sc.height/r.height)};}
  function scratch(e){
    if(!isS||done)return;e.preventDefault();
    const p=gPos(e);
    ctx.beginPath();ctx.arc(p.x,p.y,28,0,Math.PI*2);ctx.fill();
    if(Math.random()<.35)spawnSparkle(e.clientX||(e.touches&&e.touches[0].clientX),e.clientY||(e.touches&&e.touches[0].clientY));
    const d=ctx.getImageData(0,0,sc.width,sc.height).data;
    let t=0,step=16,tot=d.length/step;
    for(let i=3;i<d.length;i+=step)if(d[i]<128)t++;
    const pct=Math.min(100,Math.round(t/tot*100));
    document.getElementById('sc-pct').textContent=pct;
    document.getElementById('sc-fill').style.width=pct+'%';
    if(pct>=65&&!done){done=true;sc.style.transition='opacity 1.2s';sc.style.opacity='0';setTimeout(()=>{for(let i=0;i<22;i++)setTimeout(spawnPetal,i*110);},400);}
  }
  sc.addEventListener('mousedown',e=>{isS=true;scratch(e);});
  sc.addEventListener('mousemove',scratch);
  document.addEventListener('mouseup',()=>isS=false);
  sc.addEventListener('touchstart',e=>{isS=true;scratch(e);},{passive:false});
  sc.addEventListener('touchmove',scratch,{passive:false});
  document.addEventListener('touchend',()=>isS=false);
}

function spawnSparkle(cx,cy){
  for(let i=0;i<4;i++){
    const el=document.createElement('div');el.className='sparkle';
    const a=Math.random()*Math.PI*2,d=18+Math.random()*42;
    const sz=1.5+Math.random()*2.5;
    el.style.cssText=`left:${cx}px;top:${cy}px;width:${sz}px;height:${sz}px;--tx:${Math.cos(a)*d}px;--ty:${Math.sin(a)*d}px;`;
    document.body.appendChild(el);setTimeout(()=>el.remove(),900);
  }
}
function spawnPetal(){
  const el=document.createElement('div');el.className='petal';
  el.textContent=['🌹','✨','💫','🌸','✦'][Math.floor(Math.random()*5)];
  el.style.cssText=`left:${5+Math.random()*90}vw;top:-30px;animation-duration:${3+Math.random()*4}s;`;
  document.body.appendChild(el);setTimeout(()=>el.remove(),7000);
}
