// ══════════════════════════════
// R3 : MÉMOIRE
// ══════════════════════════════
const EMOJIS=['🍕','🎸','🦊','🌮','🎯','🍦'];
let mCards=[],mFlipped=[],mMatched=0,mLocked=false;

function initR3(){
  mMatched=0;mFlipped=[];mLocked=false;
  document.getElementById('r3-st').textContent='Retrouve toutes les paires !';
  document.getElementById('r3-fb').style.opacity='0';
  const pairs=[...EMOJIS,...EMOJIS].sort(()=>Math.random()-.5);
  const grid=document.getElementById('mem-grid');grid.innerHTML='';
  mCards=pairs.map((emoji,i)=>{
    const d=document.createElement('div');
    d.className='mc';d.dataset.e=emoji;
    d.innerHTML=`<span>${emoji}</span><div class="bk">✦</div>`;
    d.onclick=()=>flipMem(d);
    grid.appendChild(d);return d;
  });
}

function flipMem(card){
  if(mLocked||card.classList.contains('flip')||card.classList.contains('mat'))return;
  card.classList.add('flip');mFlipped.push(card);
  if(mFlipped.length===2){
    mLocked=true;
    const[a,b]=mFlipped;
    if(a.dataset.e===b.dataset.e){
      a.classList.add('mat');b.classList.add('mat');
      mMatched++;addScore(1);mFlipped=[];mLocked=false;
      document.getElementById('r3-st').textContent=`${mMatched}/6 paires trouvées`;
      if(mMatched===6)setTimeout(endR3,700);
    } else {
      setTimeout(()=>{a.classList.remove('flip');b.classList.remove('flip');mFlipped=[];mLocked=false;},950);
    }
  }
}

function endR3(){
  transition(4,'Réflexes','8 cibles, sois rapide',()=>{initR4();show('s-r4');setHud(4);});
}

